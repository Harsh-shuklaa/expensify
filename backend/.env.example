# Server Configuration
PORT=8000
NODE_ENV=production
CLIENT_URL=https://your-frontend-domain.com
FRONTEND_URL=https://your-frontend-domain.com

# Database Configuration
MONGO_URI=mongodb+srv://<db_username>:<db_password>@<db_cluster>.mongodb.net/<database_name>?retryWrites=true&w=majority

# Authentication Configuration
JWT_SECRET=your_super_secret_jwt_key_here

# SMTP / Email Configuration (For sending feedback/alerts/activation emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password_here
SMTP_FROM="Expensify Support <your_email@gmail.com>"
