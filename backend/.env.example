# Server Configuration
PORT=8000
NODE_ENV=production
CLIENT_URL=https://your-frontend-domain.com
FRONTEND_URL=https://your-frontend-domain.com

# Database Configuration
MONGO_URI=mongodb+srv://<db_username>:<db_password>@<db_cluster>.mongodb.net/<database_name>?retryWrites=true&w=majority

# Authentication Configuration
JWT_SECRET=your_super_secret_jwt_key_here

# Resend API — Email Delivery (Required)
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email sender address (use onboarding@resend.dev for testing, custom domain for production)
FROM_EMAIL=Expensify <onboarding@resend.dev>

# Admin email for receiving support/feedback notifications
ADMIN_EMAIL=your_admin_email@gmail.com

# Admin secret for diagnostic endpoints (e.g. /api/v1/health/test-email)
# ADMIN_SECRET=your_admin_secret_here
