# Server Configuration
PORT=8000
NODE_ENV=production
CLIENT_URL=https://your-frontend-domain.com
FRONTEND_URL=https://your-frontend-domain.com

# Database Configuration
MONGO_URI=mongodb+srv://<db_username>:<db_password>@<db_cluster>.mongodb.net/<database_name>?retryWrites=true&w=majority

# Authentication Configuration
JWT_SECRET=your_super_secret_jwt_key_here

# SMTP / Email Configuration (For sending OTP/feedback/alerts emails)
# Gmail: Use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password_here
SMTP_FROM="Expensify Support <your_email@gmail.com>"

# Resend API (Recommended for platforms that block SMTP ports like Render Free Tier)
# Sign up at https://resend.com and create an API key
# RESEND_API_KEY=re_xxxxxxxx

# Admin secret for diagnostic endpoints (e.g. /api/v1/health/test-email)
# ADMIN_SECRET=your_admin_secret_here
